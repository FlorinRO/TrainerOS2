{
  "cli": {
    "version": ">= 18.0.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "env": {
        "EXPO_PUBLIC_ENABLE_IOS_EXTERNAL_CHECKOUT": "true"
      },
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "env": {
        "EXPO_PUBLIC_ENABLE_IOS_EXTERNAL_CHECKOUT": "true"
      },
      "distribution": "internal"
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_ENABLE_IOS_EXTERNAL_CHECKOUT": "false"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
