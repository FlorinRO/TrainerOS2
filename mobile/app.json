{
  "expo": {
    "name": "TrainerOS",
    "slug": "traineros",
    "scheme": "traineros",
    "version": "1.0.0",
    "icon": "./assets/icon-from-frontend.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-from-frontend.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.traineros.app",
      "splash": {
        "image": "./assets/splash-from-frontend.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F172A"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.traineros.app",
      "splash": {
        "image": "./assets/splash-from-frontend.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F172A"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-from-frontend.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/icon-from-frontend.png"
    },
    "extra": {
      "eas": {
        "projectId": "9dbb9d11-687d-4119-a0b6-770a584d6999"
      }
    }
  }
}
